# PostgreSQL connection. With Homebrew Postgres, include your macOS username:
# postgresql://<user>@localhost:5432/comparador
DATABASE_URL=postgresql://localhost:5432/comparador

# Redis connection (BullMQ)
REDIS_URL=redis://127.0.0.1:6379

# Minimum delay between requests to the same host, in ms (politeness)
SCRAPE_MIN_INTERVAL_MS=1000
